  "bayesplot", "emmeans", "tidybayes", "bayestestR", "future",
  "GGally", "here", "janitor", "RColorBrewer", "reshape2", "arrow", "pins", "usethis",
  "ggtext", "forcats", "cowplot", "ggdendro", "gplots", "cmdstanr", "Rgraphviz",
  "nadiv", "graph4lg", "marginaleffects", "rethinking"
)

ipak(packages)

bayesplot::color_scheme_set("blue")
